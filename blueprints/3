function addLog(msg) {
  const entry = `[${new Date().toLocaleTimeString()}] ${msg}`;
  state.eventLog.unshift(entry);
  if (state.eventLog.length > 200) state.eventLog.length = 200;
  broadcast({ type: 'log', data: entry });
}

