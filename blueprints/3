let ws;
let state = {};

function connect() {
  const proto = location.protocol === 'https:' ? 'wss' : 'ws';
  ws = new WebSocket(`${proto}://${location.host}`);

  ws.onopen = () => console.log('рҹ§  Connected to Master Cockpit');

  ws.onmessage = (e) => {
    const msg = JSON.parse(e.data);
    if (msg.type === 'state') {
      state = msg.data;
      render();
    } else if (msg.type === 'log' || msg.type === 'pipeline_result' || msg.type === 'test_results') {
      // State update will follow on next tick
    }
  };

  ws.onclose = () => {
    console.log('Disconnected вҖ” reconnecting in 2s...');
    setTimeout(connect, 2000);
  };

  ws.onerror = () => ws.close();
}

function send(action, extra) {
  if (ws && ws.readyState === 1) {
    ws.send(JSON.stringify({ action, ...extra }));
  }
}

connect();

