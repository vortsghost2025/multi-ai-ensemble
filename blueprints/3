    { id: 'lingma', name: 'Lingma (Research)', status: 'running', cpu: 38, memory: 55, tasks: 3, completed: 892, errors: 0, uptime: 90.5 },
    { id: 'claude', name: 'Claude (Coding)', status: 'running', cpu: 52, memory: 68, tasks: 5, completed: 1456, errors: 0, uptime: 90.5 },
    { id: 'glm', name: 'GLM (Analysis)', status: 'running', cpu: 41, memory: 58, tasks: 4, completed: 1034, errors: 0, uptime: 90.5 },
    { id: 'copilot', name: 'Copilot (Review)', status: 'running', cpu: 35, memory: 50, tasks: 2, completed: 678, errors: 0, uptime: 90.5 },
  ],
