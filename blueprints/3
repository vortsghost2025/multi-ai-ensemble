// SIMULATION TICK (1 second)
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
setInterval(() => {
  // Update agent metrics
  state.agents.forEach(a => {
    if (a.status === 'running') {
      a.cpu = Math.max(5, Math.min(95, a.cpu + (Math.random() - 0.5) * 10));
      a.memory = Math.max(20, Math.min(90, a.memory + (Math.random() - 0.5) * 5));
      a.tasks = Math.max(0, a.tasks + Math.floor(Math.random() * 3) - 1);
      a.completed += Math.floor(Math.random() * 3);
      a.uptime += 1 / 3600;
    }
  });

  // Update system metrics
  state.metrics.cpu = Math.max(10, Math.min(95, state.metrics.cpu + (Math.random() - 0.5) * 8));
  state.metrics.memory = Math.max(20, Math.min(95, state.metrics.memory + (Math.random() - 0.5) * 4));
  state.metrics.disk = Math.max(30, Math.min(95, state.metrics.disk + (Math.random() - 0.3) * 2));
  state.metrics.network = Math.max(1, Math.min(50, state.metrics.network + (Math.random() - 0.5) * 5));
  state.metrics.uptime += 1 / 3600;

  // Update swarm nodes
  if (state.swarm.active) {
    state.swarm.nodes.forEach(n => {
      n.tasks = Math.max(0, n.tasks + Math.floor(Math.random() * 5) - 2);
      n.status = Math.random() > 0.1 ? 'active' : 'syncing';
    });
  }

  state.totalCompleted += Math.floor(Math.random() * 5);

  // Autonomous mode
  if (state.swarm.autonomous && state.swarm.active && Math.random() > 0.7) {
    const idleNodes = state.swarm.nodes.filter(n => n.tasks < 3);
    if (idleNodes.length > 0) {
      idleNodes.forEach(n => { n.tasks += Math.floor(Math.random() * 5) + 1; });
      addLog('[AUTO] Distributed tasks to idle nodes');
    }
  }

  broadcast({ type: 'state', data: getPublicState() });
}, 1000);

function getPublicState() {
  return {
    agents: state.agents,
    swarm: state.swarm,
    metrics: state.metrics,
    totalCompleted: state.totalCompleted,
    totalErrors: state.totalErrors,
    pipelineResults: state.pipelineResults.slice(0, 50),
    testResults: state.testResults.slice(0, 100),
    healingEvents: state.healingEvents.slice(0, 30),
    eventLog: state.eventLog.slice(0, 50),
  };
}

