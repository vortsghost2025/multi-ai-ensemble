  document.getElementById('sw-auto-label').textContent = isOn ? 'ACTIVE' : 'OFF';
  document.getElementById('sw-auto-label').style.color = isOn ? 'var(--green)' : '#666';
  send('swarm_autonomous', { enabled: isOn });
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// RENDER HELPERS
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function metricBar(label, value, color, unit) {
  unit = unit || '%';
  const pct = Math.min(value, 100);
  const c = pct > 90 ? 'var(--red)' : pct > 70 ? 'var(--yellow)' : color;
  return `<div class="metric">
    <div class="metric-header"><span class="metric-label">${label}</span><span class="metric-value" style="color:${c}">${value.toFixed(1)}${unit}</span></div>
    <div class="metric-track"><div class="metric-fill" style="width:${pct}%;background:${c}"></div></div>
  </div>`;
}

function statBox(value, label, color) {
  return `<div class="stat-box"><div class="value" style="color:${color}">${value}</div><div class="label">${label}</div></div>`;
}

function dotClass(status) {
  if (['running', 'active', 'pass', 'complete'].includes(status)) return 'green';
  if (['idle', 'syncing', 'queued', 'initializing'].includes(status)) return 'cyan';
  return 'red';
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
// MAIN RENDER
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function render() {
  if (!state.agents) return;

  const running = state.agents.filter(a => a.status === 'running').length;
  const nodeCount = state.swarm ? state.swarm.nodes.length : 0;

  // Header
  document.getElementById('h-agents').textContent = running;
  document.getElementById('h-nodes').textContent = nodeCount;
  document.getElementById('h-ops').textContent = state.totalCompleted.toLocaleString() + ' ops';

  // Footer
  document.getElementById('footer-time').textContent = `16GB RAM вҖў Local Network вҖў ${new Date().toLocaleString()}`;

  renderMaster();
  renderSwarm();
  renderAgents();
  renderPipeline();
  renderTests();
  renderMemory();
  renderHealing();
}

// в•җв•җв•җ MASTER в•җв•җв•җ
function renderMaster() {
  const m = state.metrics;
  document.getElementById('m-agents-active').textContent = state.agents.filter(a => a.status === 'running').length;
  document.getElementById('m-swarm-nodes').textContent = state.swarm.nodes.length;
  document.getElementById('m-completed').textContent = state.totalCompleted.toLocaleString();
  document.getElementById('m-errors').textContent = state.totalErrors;
  document.getElementById('m-errors').style.color = state.totalErrors > 0 ? 'var(--red)' : 'var(--green)';

  document.getElementById('m-metrics').innerHTML =
    metricBar('CPU', m.cpu, 'var(--cyan)') +
    metricBar('Memory', m.memory, 'var(--green)') +
    metricBar('Disk', m.disk, 'var(--yellow)') +
    metricBar('Network I/O', m.network, 'var(--pink)', ' MB/s');

  document.getElementById('m-uptime').textContent = `Uptime: ${m.uptime.toFixed(1)}h | 16GB RAM | Local Network`;

  document.getElementById('m-agent-grid').innerHTML = state.agents.map(a => `
    <div class="agent-mini ${a.status !== 'running' ? 'idle' : ''}">
      <span class="dot ${dotClass(a.status)}"></span>
      <div class="name">${a.name.split(' ')[0]}</div>
      <div style="font-size:10px;color:#888">${a.status}</div>
      <div style="font-size:18px;font-weight:bold;color:#fff;margin:4px 0">${a.completed}</div>
      <div style="font-size:9px;color:#666">completed</div>
    </div>
  `).join('');

  document.getElementById('m-log').innerHTML = (state.eventLog || []).slice(0, 20).map(l => {
    let cls = 'log-item';
    if (l.includes('HEAL')) cls += ' heal';
    else if (l.includes('PIPELINE')) cls += ' pipeline';
    else if (l.includes('ERROR')) cls += ' error';
    else if (l.includes('SWARM')) cls += ' swarm';
    return `<div class="${cls}">${l}</div>`;
  }).join('');
}

// в•җв•җв•җ SWARM в•җв•җв•җ
function renderSwarm() {
  const sw = state.swarm;
  if (!sw) return;

  if (sw.nodes.length === 0) {
    document.getElementById('sw-nodes').innerHTML = '<div class="empty">Initialize swarm to see nodes</div>';
  } else {
    document.getElementById('sw-nodes').innerHTML = sw.nodes.map(n => `
      <div class="node-mini">
        <span class="dot ${dotClass(n.status)}"></span>
        <div style="font-size:11px;font-weight:bold;color:var(--cyan);margin-top:4px">${n.id}</div>
        <div style="font-size:20px;font-weight:bold;color:#fff">${n.tasks}</div>
        <div style="font-size:9px;color:#666">tasks | ${n.agents} agents</div>
      </div>
    `).join('');
  }

  const activeTasks = sw.nodes.reduce((s, n) => s + n.tasks, 0);
  document.getElementById('sw-stats').innerHTML =
    statBox(sw.nodes.length, 'Total Nodes', 'var(--cyan)') +
    statBox(activeTasks, 'Active Tasks', 'var(--green)') +
    statBox(sw.totalJobs || 0, 'Jobs Queued', 'var(--yellow)') +
    statBox(state.totalCompleted.toLocaleString(), 'Total Completed', 'var(--pink)');
}

// в•җв•җв•җ AGENTS в•җв•җв•җ
function renderAgents() {
  document.getElementById('ag-cards').innerHTML = state.agents.map(a => `
    <div class="card">
      <div class="card-title">${a.status === 'running' ? 'рҹҹў' : 'рҹҹЎ'} ${a.name}</div>
      <div style="margin-bottom:12px">
        <span class="dot ${dotClass(a.status)}"></span>
        <span style="font-size:12px;color:#aaa;text-transform:uppercase">${a.status}</span>
        <span style="float:right;font-size:11px;color:#666">${a.uptime.toFixed(1)}h uptime</span>
      </div>
      ${metricBar('CPU Usage', a.cpu, 'var(--cyan)')}
      ${metricBar('Memory', a.memory, 'var(--green)')}
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:12px">
        <div class="stat-box sm"><div class="value" style="color:var(--cyan)">${a.tasks}</div><div class="label">Active</div></div>
        <div class="stat-box sm"><div class="value" style="color:var(--green)">${a.completed}</div><div class="label">Done</div></div>
        <div class="stat-box sm"><div class="value" style="color:${a.errors > 0 ? 'var(--red)' : 'var(--green)'}">${a.errors}</div><div class="label">Errors</div></div>
      </div>
    </div>
  `).join('');
}

// в•җв•җв•җ PIPELINE в•җв•җв•җ
function renderPipeline() {
  const results = state.pipelineResults || [];
  const medical = results.filter(r => r.type === 'medical');
  const genomics = results.filter(r => r.type === 'genomics');

  function renderResults(arr) {
    return arr.map(r => {
      const color = r.duration === 0 ? 'var(--pink)' : r.duration <= 1 ? 'var(--green)' : 'var(--cyan)';
      const borderColor = r.duration === 0 ? 'var(--pink)' : r.duration <= 1 ? 'var(--green)' : 'var(--cyan)';
      const msg = r.duration === 0 ? 'вҡЎ QUANTUM SPEED вҖ” Zero MS Pipeline Complete!' :
        r.duration <= 1 ? 'рҹ”Ҙ Microsecond Magic вҖ” Faster than human perception!' :
        `вң… ${r.agents} agents parallel | Risk flag: ${r.riskFlag}`;
      return `<div class="result-item" style="border-left:3px solid ${borderColor}">
        <div>
          <div class="speed" style="color:${color}">${r.duration}ms</div>
          <div class="detail">${msg}</div>
        </div>
        <div style="text-align:right;font-size:10px;color:#555">${new Date(r.timestamp).toLocaleTimeString()}</div>
      </div>`;
    }).join('');
  }

  document.getElementById('pl-medical').innerHTML = medical.length ? renderResults(medical) : '<div class="empty">Run a pipeline to see results</div>';
  document.getElementById('pl-genomics').innerHTML = genomics.length ? renderResults(genomics) : '<div class="empty">Run a pipeline to see results</div>';

  const avg = results.length > 0 ? (results.reduce((s, r) => s + r.duration, 0) / results.length).toFixed(1) + 'ms' : 'вҖ”';
  const zeros = results.filter(r => r.duration === 0).length;
  document.getElementById('pl-stats').innerHTML =
    statBox(results.length, 'Total Runs', 'var(--cyan)') +
    statBox(avg, 'Avg Speed', 'var(--green)') +
    statBox(zeros, 'Zero-MS Runs', 'var(--pink)') +
    statBox('100%', 'Success Rate', 'var(--green)');
}

// в•җв•җв•җ TESTS в•җв•җв•җ
function renderTests() {
  const tests = state.testResults || [];

  document.getElementById('ts-results').innerHTML = tests.length === 0
    ? '<div class="empty">Run tests to see results</div>'
    : tests.map(t => `
      <div class="result-item" style="border-left:3px solid ${t.status === 'pass' ? 'var(--green)' : 'var(--red)'}">
        <div>
          <div style="font-size:13px;font-weight:bold;color:${t.status === 'pass' ? 'var(--green)' : 'var(--red)'}">
            ${t.status === 'pass' ? 'вң“' : 'вң—'} ${t.name}
          </div>
          <div class="detail">${t.details}</div>
        </div>
        <div style="text-align:right">
          <div style="font-size:14px;font-weight:bold;color:var(--cyan)">${t.duration}ms</div>
          <div style="font-size:9px;color:#555">${new Date(t.timestamp).toLocaleTimeString()}</div>
        </div>
      </div>
    `).join('');

  const passed = tests.filter(t => t.status === 'pass').length;
  const failed = tests.filter(t => t.status === 'fail').length;
  const rate = tests.length > 0 ? ((passed / tests.length) * 100).toFixed(0) + '%' : 'вҖ”';
  document.getElementById('ts-stats').innerHTML =
    statBox(tests.length, 'Total Tests', 'var(--cyan)') +
    statBox(passed, 'Passed', 'var(--green)') +
    statBox(failed, 'Failed', 'var(--red)') +
    statBox(rate, 'Success Rate', 'var(--green)');
}

// в•җв•җв•җ MEMORY (only needs to render once) в•җв•җв•җ
