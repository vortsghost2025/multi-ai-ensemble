function useSimulation() {
  const [agents, setAgents] = useState<Agent[]>([
    { id: 'kilo', name: 'Kilo (Master)', status: 'running', cpu: 45, memory: 62, tasks: 8, completed: 1247, errors: 0, uptime: 90.5 },
    { id: 'lingma', name: 'Lingma (Research)', status: 'running', cpu: 38, memory: 55, tasks: 3, completed: 892, errors: 0, uptime: 90.5 },
    { id: 'claude', name: 'Claude (Coding)', status: 'running', cpu: 52, memory: 68, tasks: 5, completed: 1456, errors: 0, uptime: 90.5 },
    { id: 'glm', name: 'GLM (Analysis)', status: 'running', cpu: 41, memory: 58, tasks: 4, completed: 1034, errors: 0, uptime: 90.5 },
    { id: 'copilot', name: 'Copilot (Review)', status: 'running', cpu: 35, memory: 50, tasks: 2, completed: 678, errors: 0, uptime: 90.5 },
  ]);

  const [swarmNodes, setSwarmNodes] = useState<SwarmNode[]>([]);
  const [testResults, setTestResults] = useState<TestResult[]>([]);
  const [pipelineResults, setPipelineResults] = useState<PipelineResult[]>([]);
  const [systemMetrics, setSystemMetrics] = useState<SystemMetrics>({ cpu: 42, memory: 58, disk: 45, network: 12, uptime: 90.5 });
  const [swarmActive, setSwarmActive] = useState(false);
  const [autonomous, setAutonomous] = useState(false);
  const [totalJobs, setTotalJobs] = useState(0);
  const [totalCompleted, setTotalCompleted] = useState(5307);
  const [totalErrors, setTotalErrors] = useState(0);
  const [healingEvents, setHealingEvents] = useState<string[]>([]);
  const [eventLog, setEventLog] = useState<string[]>([
    '[SYSTEM] Master Cockpit initialized',
    '[SYSTEM] All 5 agents connected',
    '[SYSTEM] WebSocket layer active',
    '[SYSTEM] Constraint lattice verified — 4 layers intact',
  ]);

  // Update metrics every second
  useEffect(() => {
    const interval = setInterval(() => {
      setAgents(prev => prev.map(a => ({
        ...a,
        cpu: Math.max(5, Math.min(95, a.cpu + (Math.random() - 0.5) * 10)),
        memory: Math.max(20, Math.min(90, a.memory + (Math.random() - 0.5) * 5)),
        tasks: a.status === 'running' ? Math.max(0, a.tasks + Math.floor(Math.random() * 3) - 1) : 0,
        completed: a.status === 'running' ? a.completed + Math.floor(Math.random() * 3) : a.completed,
        uptime: a.uptime + 1 / 3600,
      })));

      setSystemMetrics(prev => ({
        cpu: Math.max(10, Math.min(95, prev.cpu + (Math.random() - 0.5) * 8)),
        memory: Math.max(20, Math.min(95, prev.memory + (Math.random() - 0.5) * 4)),
        disk: Math.max(30, Math.min(95, prev.disk + (Math.random() - 0.3) * 2)),
        network: Math.max(1, Math.min(50, prev.network + (Math.random() - 0.5) * 5)),
        uptime: prev.uptime + 1 / 3600,
      }));

      if (swarmActive) {
        setSwarmNodes(prev => prev.map(n => ({
          ...n,
          tasks: Math.max(0, n.tasks + Math.floor(Math.random() * 5) - 2),
          status: Math.random() > 0.1 ? 'active' : 'syncing' as any,
        })));
      }

      setTotalCompleted(prev => prev + Math.floor(Math.random() * 5));
    }, 1000);
    return () => clearInterval(interval);
  }, [swarmActive]);

  const initializeSwarm = useCallback((nodeCount: number) => {
    const nodes: SwarmNode[] = Array.from({ length: nodeCount }, (_, i) => ({
      id: `node-${i + 1}`,
      agents: Math.floor(Math.random() * 3) + 1,
      tasks: 0,
      status: 'active' as const,
    }));
    setSwarmNodes(nodes);
    setSwarmActive(true);
    addLog(`[SWARM] Initialized ${nodeCount} nodes`);
  }, []);

  const optimizeSwarm = useCallback(() => {
    setSwarmNodes(prev => prev.map(n => ({ ...n, status: 'active' as const, tasks: Math.floor(n.tasks * 0.7) })));
    addLog('[SWARM] Optimization pass complete');
  }, []);

  const rebalanceSwarm = useCallback(() => {
    setSwarmNodes(prev => {
      const totalTasks = prev.reduce((sum, n) => sum + n.tasks, 0);
      const perNode = Math.floor(totalTasks / prev.length);
      return prev.map(n => ({ ...n, tasks: perNode, status: 'syncing' as const }));
    });
    addLog('[SWARM] Work rebalanced across nodes');
  }, []);

  const queueJobs = useCallback((count: number) => {
    setTotalJobs(prev => prev + count);
    setSwarmNodes(prev => prev.map(n => ({
      ...n,
      tasks: n.tasks + Math.floor(count / Math.max(prev.length, 1)),
    })));
    addLog(`[SWARM] Queued ${count} jobs`);
  }, []);

  const runPipeline = useCallback((type: 'medical' | 'genomics') => {
    const duration = Math.random() < 0.3 ? 0 : Math.random() < 0.5 ? 1 : Math.floor(Math.random() * 5);
    const result: PipelineResult = {
      id: `pl-${Date.now()}`,
      type,
      duration,
      status: 'complete',
      agents: 5,
      riskFlag: type === 'medical' ? 0.9 : 0.7,
      timestamp: Date.now(),
    };
    setPipelineResults(prev => [result, ...prev].slice(0, 50));
    addLog(`[PIPELINE] ${type.toUpperCase()} complete in ${duration}ms — ${duration === 0 ? '⚡ QUANTUM SPEED' : duration <= 1 ? '🔥 MICROSECOND MAGIC' : '✅ Fast'}`);
    return result;
  }, []);

  const runAllPipelines = useCallback(() => {
    for (let i = 0; i < 5; i++) {
      setTimeout(() => {
        runPipeline(i % 2 === 0 ? 'medical' : 'genomics');
      }, i * 100);
    }
  }, [runPipeline]);

  const runTests = useCallback(() => {
    const tests: TestResult[] = [
      { id: `t-${Date.now()}-1`, name: 'Constitutional Symmetry', status: 'pass', duration: 2, timestamp: Date.now(), details: 'All layers consistent' },
      { id: `t-${Date.now()}-2`, name: 'Constraint Propagation', status: 'pass', duration: 1, timestamp: Date.now(), details: 'L1→L2→L3→L4 verified' },
      { id: `t-${Date.now()}-3`, name: 'CPS Drift Detection', status: 'pass', duration: 3, timestamp: Date.now(), details: 'Score 0.82 — stable attractor' },
      { id: `t-${Date.now()}-4`, name: 'Integrity Verification', status: 'pass', duration: 1, timestamp: Date.now(), details: 'SHA-256 manifest valid' },
      { id: `t-${Date.now()}-5`, name: 'Checkpoint Recovery', status: 'pass', duration: 2, timestamp: Date.now(), details: 'Functorial — Δ ≤ 0.02' },
      { id: `t-${Date.now()}-6`, name: 'Parallel Operations (50)', status: 'pass', duration: 4, timestamp: Date.now(), details: '50/50 — 100% success' },
    ];
    setTestResults(prev => [...tests, ...prev].slice(0, 100));
    addLog('[TESTS] 6/6 passed — 100% success rate');
  }, []);

  const triggerSelfHeal = useCallback(() => {
    const events = [
      'Memory pressure detected — releasing cached swarm data',
      'Agent #3 heartbeat delayed — reconnecting WebSocket',
      'Task queue overflow — redistributing to idle nodes',
      'Disk I/O spike — throttling write operations',
      'Network timeout — retrying with exponential backoff',
    ];
    const event = events[Math.floor(Math.random() * events.length)];
    setHealingEvents(prev => [`[${new Date().toLocaleTimeString()}] ${event}`, ...prev].slice(0, 20));
    addLog(`[HEAL] ${event}`);
  }, []);

  const addLog = useCallback((msg: string) => {
    setEventLog(prev => [`[${new Date().toLocaleTimeString()}] ${msg}`, ...prev].slice(0, 100));
  }, []);

  return {
    agents, swarmNodes, testResults, pipelineResults, systemMetrics,
    swarmActive, autonomous, setAutonomous,
    totalJobs, totalCompleted, totalErrors, healingEvents, eventLog,
    initializeSwarm, optimizeSwarm, rebalanceSwarm, queueJobs,
    runPipeline, runAllPipelines, runTests, triggerSelfHeal, addLog,
  };
}

