function StatusDot({ status }: { status: string }) {
  const colors: Record<string, string> = {
    running: '#00ff88', active: '#00ff88', pass: '#00ff88', complete: '#00ff88',
    idle: '#ffaa00', syncing: '#00d4ff', queued: '#00d4ff', initializing: '#00d4ff',
    error: '#ff4444', fail: '#ff4444',
  };
  return (
    <span style={{
      display: 'inline-block', width: 8, height: 8, borderRadius: '50%',
      backgroundColor: colors[status] || '#666',
      boxShadow: `0 0 6px ${colors[status] || '#666'}`,
      animation: status === 'running' || status === 'active' ? 'pulse 2s infinite' : 'none',
    }} />
  );
}

function MetricBar({ label, value, max = 100, color = '#00d4ff', unit = '%' }: {
  label: string; value: number; max?: number; color?: string; unit?: string;
}) {
  const pct = Math.min((value / max) * 100, 100);
  const barColor = pct > 90 ? '#ff4444' : pct > 70 ? '#ffaa00' : color;
  return (
    <div style={{ marginBottom: 8 }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: 12, marginBottom: 2 }}>
        <span style={{ color: '#aaa' }}>{label}</span>
        <span style={{ color: barColor, fontWeight: 'bold' }}>{value.toFixed(1)}{unit}</span>
      </div>
      <div style={{ height: 6, background: '#1a1a2e', borderRadius: 3, overflow: 'hidden' }}>
        <div style={{
          height: '100%', width: `${pct}%`, background: `linear-gradient(90deg, ${barColor}, ${barColor}88)`,
          borderRadius: 3, transition: 'width 0.5s ease',
        }} />
      </div>
    </div>
  );
}

function Card({ title, children, style }: { title?: string; children: React.ReactNode; style?: React.CSSProperties }) {
  return (
    <div style={{
      background: 'linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)',
      border: '1px solid #2a2a4a', borderRadius: 8, padding: 16,
      ...style,
    }} className="animate-in">
      {title && <h3 style={{ fontSize: 14, color: '#00d4ff', marginBottom: 12, textTransform: 'uppercase', letterSpacing: 1 }}>{title}</h3>}
      {children}
    </div>
  );
}

function Button({ children, onClick, variant = 'primary', style }: {
  children: React.ReactNode; onClick: () => void; variant?: 'primary' | 'secondary' | 'danger' | 'success';
  style?: React.CSSProperties;
}) {
  const colors = {
    primary: { bg: '#00d4ff', text: '#000' },
    secondary: { bg: '#2a2a4a', text: '#00d4ff' },
    danger: { bg: '#ff4444', text: '#fff' },
    success: { bg: '#00ff88', text: '#000' },
  };
  return (
    <button onClick={onClick} style={{
      padding: '8px 16px', borderRadius: 6, border: 'none', cursor: 'pointer',
      fontWeight: 'bold', fontSize: 12, textTransform: 'uppercase', letterSpacing: 1,
      background: colors[variant].bg, color: colors[variant].text,
      transition: 'all 0.2s', ...style,
    }}
      onMouseEnter={e => (e.currentTarget.style.opacity = '0.8')}
      onMouseLeave={e => (e.currentTarget.style.opacity = '1')}
    >{children}</button>
  );
}

